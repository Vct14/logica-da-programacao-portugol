algoritmo "semnome"
// Função :
// Autor :
// Data : 21/07/2026
// Seção de Declarações 
var
X, Y: Inteiro
Procedimento Soma(A, B: Inteiro)
inicio
      EscrevaL("Recebi o Valor", A)
      Escreval("Recebu o Valor", B)
      EscrevaL("A soma entre os dois é ", A + B)
FimProcedimento
inicio
      X <- 5
      Y<- 3
      Soma(X, Y)
fimalgoritmo
