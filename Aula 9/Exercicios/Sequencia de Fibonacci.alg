algoritmo "semnome"
// Função :
// Autor :
// Data : 7/17/2026
// Seção de Declarações 
var
A, B, Soma, Cont: Inteiro
inicio
// Seção de Comandos 
A <- 0
B <- 1
escreva(A, " ", B, " ")
           para Cont <- 1 ate 13 faca
                Soma <- A + b
                A <- B
                B <- Soma
                Escreva(Soma, " ")
           FimPara

fimalgoritmo
